generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String            @id @default(cuid())
  email                  String            @unique
  passwordHash           String
  displayName            String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  sessions               Session[]
  memberships            WorkspaceMember[]
  acceptedConsentRecords ConsentRecord[]
  reviewedSafetyEvents   SafetyEvent[]
  resolvedKnowledgeGaps  KnowledgeGap[]
  createdApiKeys         ApiKey[]           @relation("ApiKeyCreatedBy")
  revokedApiKeys         ApiKey[]           @relation("ApiKeyRevokedBy")
  createdWebhookEndpoints WebhookEndpoint[] @relation("WebhookEndpointCreatedBy")
  revokedWebhookEndpoints WebhookEndpoint[] @relation("WebhookEndpointRevokedBy")
}

model Workspace {
  id             String            @id @default(cuid())
  name           String
  slug           String            @unique
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  members        WorkspaceMember[]
  avatars        Avatar[]
  leads          Lead[]
  consentRecords ConsentRecord[]
  knowledgeSources KnowledgeSource[]
  knowledgeChunks  KnowledgeChunk[]
  widgetSettings  WidgetSettings[]
  allowedDomains  AllowedDomain[]
  usageEvents     UsageEvent[]
  safetyEvents    SafetyEvent[]
  knowledgeGaps   KnowledgeGap[]
  realtimeSessions RealtimeSession[]
  apiKeys          ApiKey[]
  webhookEndpoints WebhookEndpoint[]
}

model Avatar {
  id                    String       @id @default(cuid())
  workspaceId           String
  voiceId               String?
  name                  String
  displayName           String
  role                  String
  useCase               String
  language              String
  greeting              String
  tone                  String
  answerStyle           String
  businessInstructions  String
  fallbackMessage      String
  leadCapturePreference String
  handoffPreference     String
  status                AvatarStatus @default(DRAFT)
  engine                AvatarEngine @default(MOCK)
  publishedAt           DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  voice           Voice?          @relation(fields: [voiceId], references: [id], onDelete: SetNull)
  photoAssets     AvatarAsset[]   @relation("AvatarPhotoAssets")
  consentRecords  ConsentRecord[]
  widgetSettings  WidgetSettings[]
  leads           Lead[]
  conversations   Conversation[]
  usageEvents     UsageEvent[]
  safetyEvents    SafetyEvent[]
  knowledgeGaps   KnowledgeGap[]
  realtimeSessions RealtimeSession[]

  @@index([workspaceId])
  @@index([voiceId])
  @@index([status])
}

model WidgetSettings {
  id              String         @id @default(cuid())
  workspaceId     String
  avatarId        String
  theme           WidgetTheme    @default(LIGHT)
  position        WidgetPosition @default(BOTTOM_RIGHT)
  greetingEnabled Boolean        @default(true)
  greetingText    String
  primaryColor    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  avatar    Avatar    @relation(fields: [avatarId], references: [id], onDelete: Cascade)

  @@unique([avatarId])
  @@index([workspaceId])
  @@index([workspaceId, avatarId])
}

model AllowedDomain {
  id          String   @id @default(cuid())
  workspaceId String
  domain      String
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, domain])
  @@index([workspaceId])
}

model Voice {
  id              String        @id @default(cuid())
  provider        VoiceProvider
  providerVoiceId String
  name            String
  language        String
  style           String
  presentationStyle String
  previewUrl      String?
  status          VoiceStatus   @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  avatars Avatar[]

  @@unique([provider, providerVoiceId])
  @@index([status])
  @@index([language])
}

model KnowledgeSource {
  id         String              @id @default(cuid())
  workspaceId String
  title      String
  type       KnowledgeSourceType
  status     KnowledgeStatus     @default(PENDING)
  rawText    String?
  sourceUrl  String?
  fileUrl    String?
  metadata   Json?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  archivedAt DateTime?

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  chunks    KnowledgeChunk[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([workspaceId, type])
}

model KnowledgeChunk {
  id          String   @id @default(cuid())
  workspaceId String
  sourceId    String
  content     String
  position    Int
  metadata    Json?
  createdAt   DateTime @default(now())

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  source    KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, position])
  @@index([workspaceId])
  @@index([sourceId])
}

model AvatarAsset {
  id               String                     @id @default(cuid())
  workspaceId      String
  avatarId         String
  type             AvatarAssetType
  storageKey       String
  displayUrl       String
  originalFileName String
  mimeType         String
  sizeBytes        Int
  width            Int
  height           Int
  validationStatus AvatarAssetValidationStatus
  validationIssues Json
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  avatar         Avatar          @relation("AvatarPhotoAssets", fields: [avatarId], references: [id], onDelete: Cascade)
  consentRecords ConsentRecord[]

  @@index([workspaceId])
  @@index([avatarId])
  @@index([avatarId, type, validationStatus])
  @@index([type])
}

model Conversation {
  id String @id @default(cuid())
  workspaceId String
  avatarId String
  visitorId String?
  channel ConversationChannel
  status ConversationStatus @default(ACTIVE)
  summary String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  endedAt DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  avatar Avatar @relation(fields: [avatarId], references: [id], onDelete: Cascade)
  messages Message[]
  runtimeTraces RuntimeTrace[]
  lead Lead?
  usageEvents UsageEvent[]
  safetyEvents SafetyEvent[]
  knowledgeGaps KnowledgeGap[]
  realtimeSessions RealtimeSession[]

  @@index([workspaceId])
  @@index([avatarId])
  @@index([workspaceId, channel])
  @@index([workspaceId, status])
  @@index([avatarId, channel, status])
  @@index([updatedAt])
}

model Message {
  id String @id @default(cuid())
  conversationId String
  role MessageRole
  content String
  audioUrl String?
  videoUrl String?
  metadata Json?
  createdAt DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  usageEvents UsageEvent[]
  safetyEvents SafetyEvent[]
  knowledgeGaps KnowledgeGap[]

  @@index([conversationId])
  @@index([role])
  @@index([createdAt])
}

model Lead {
  id             String     @id @default(cuid())
  workspaceId    String
  conversationId String     @unique
  avatarId       String?
  name           String?
  email          String?
  phone          String?
  message        String?
  source         LeadSource
  status         LeadStatus @default(NEW)
  metadata       Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  avatar       Avatar?      @relation(fields: [avatarId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([avatarId])
  @@index([workspaceId, status])
  @@index([workspaceId, source])
  @@index([createdAt])
}

model RuntimeTrace {
  id String @id @default(cuid())
  workspaceId String
  avatarId String?
  conversationId String?
  eventType String
  durationMs Int?
  status RuntimeTraceStatus
  metadata Json?
  createdAt DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  avatar Avatar? @relation(fields: [avatarId], references: [id], onDelete: SetNull)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([avatarId])
  @@index([conversationId])
  @@index([eventType])
  @@index([status])
  @@index([createdAt])
}

model UsageEvent {
  id                String   @id @default(cuid())
  workspaceId       String
  avatarId          String?
  conversationId    String?
  messageId         String?
  eventType         String
  quantity          Float
  unit              String
  provider          String?
  costEstimateCents Float?
  metadata          Json?
  idempotencyKey    String?  @unique
  createdAt         DateTime @default(now())

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  avatar       Avatar?       @relation(fields: [avatarId], references: [id], onDelete: SetNull)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  message      Message?      @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([avatarId])
  @@index([conversationId])
  @@index([messageId])
  @@index([eventType])
  @@index([unit])
  @@index([createdAt])
  @@index([workspaceId, eventType, createdAt])
}

model SafetyEvent {
  id                 String            @id @default(cuid())
  workspaceId        String
  avatarId           String?
  conversationId     String?
  messageId          String?
  eventType          SafetyEventType
  severity           SafetySeverity
  status             SafetyEventStatus @default(OPEN)
  action             SafetyAction
  source             SafetySource
  inputExcerpt       String?
  outputExcerpt      String?
  reason             String?
  metadata           Json?
  createdAt          DateTime          @default(now())
  reviewedAt         DateTime?
  reviewedByUserId   String?

  workspace        Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  avatar           Avatar?       @relation(fields: [avatarId], references: [id], onDelete: SetNull)
  conversation     Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  message          Message?      @relation(fields: [messageId], references: [id], onDelete: SetNull)
  reviewedByUser   User?         @relation(fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([avatarId])
  @@index([conversationId])
  @@index([messageId])
  @@index([eventType])
  @@index([severity])
  @@index([status])
  @@index([source])
  @@index([createdAt])
  @@index([workspaceId, status, createdAt])
}

model KnowledgeGap {
  id               String             @id @default(cuid())
  workspaceId      String
  avatarId         String?
  conversationId   String?
  messageId        String?
  question         String
  normalizedQuestion String?
  reason           KnowledgeGapReason
  status           KnowledgeGapStatus @default(NEW)
  frequency        Int                @default(1)
  lastAskedAt      DateTime           @default(now())
  suggestedAnswer  String?
  source           KnowledgeGapSource
  metadata         Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  resolvedAt       DateTime?
  resolvedByUserId String?

  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  avatar         Avatar?       @relation(fields: [avatarId], references: [id], onDelete: SetNull)
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  message        Message?      @relation(fields: [messageId], references: [id], onDelete: SetNull)
  resolvedByUser User?         @relation(fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([avatarId])
  @@index([conversationId])
  @@index([messageId])
  @@index([reason])
  @@index([status])
  @@index([source])
  @@index([lastAskedAt])
  @@index([workspaceId, status, lastAskedAt])
  @@index([workspaceId, avatarId, normalizedQuestion, status])
}

model RealtimeSession {
  id             String                @id @default(cuid())
  workspaceId    String
  avatarId       String
  conversationId String?
  channel        RealtimeSessionChannel
  status         RealtimeSessionStatus @default(STARTING)
  visitorId      String?
  startedAt      DateTime              @default(now())
  endedAt        DateTime?
  lastEventAt    DateTime?
  metadata       Json?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  avatar       Avatar        @relation(fields: [avatarId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([avatarId])
  @@index([conversationId])
  @@index([channel])
  @@index([status])
  @@index([visitorId])
  @@index([startedAt])
  @@index([lastEventAt])
  @@index([workspaceId, status, lastEventAt])
}

model ApiKey {
  id              String    @id @default(cuid())
  workspaceId     String
  name            String
  prefix          String    @unique
  keyHash         String    @unique
  scopes          String[]
  createdByUserId String
  revokedByUserId String?
  lastUsedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdByUser User      @relation("ApiKeyCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  revokedByUser User?     @relation("ApiKeyRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([workspaceId, revokedAt])
  @@index([createdByUserId])
}

model WebhookEndpoint {
  id                String    @id @default(cuid())
  workspaceId       String
  url               String
  description       String?
  events            String[]
  signingSecretHash String @unique
  signingSecretPrefix String @unique
  createdByUserId   String
  revokedByUserId   String?
  lastDeliveryAt    DateTime?
  revokedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdByUser User      @relation("WebhookEndpointCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  revokedByUser User?     @relation("WebhookEndpointRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([workspaceId, revokedAt])
  @@index([createdByUserId])
}

model ConsentRecord {
  id                String          @id @default(cuid())
  workspaceId       String
  avatarId          String
  avatarAssetId     String
  acceptedByUserId  String
  consentType       ConsentType
  permissionBasis   PermissionBasis
  termsVersion      String
  acceptedIp        String?
  acceptedUserAgent String?
  acceptedAt        DateTime        @default(now())
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  workspace      Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  avatar         Avatar      @relation(fields: [avatarId], references: [id], onDelete: Cascade)
  avatarAsset    AvatarAsset @relation(fields: [avatarAssetId], references: [id], onDelete: Restrict)
  acceptedByUser User        @relation(fields: [acceptedByUserId], references: [id], onDelete: Restrict)

  @@unique([avatarAssetId])
  @@index([workspaceId])
  @@index([avatarId])
  @@index([acceptedByUserId])
  @@index([avatarId, avatarAssetId])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

enum WorkspaceRole {
  OWNER
  ADMIN
  OPERATOR
  VIEWER
}

enum AvatarStatus {
  DRAFT
  PROCESSING
  READY
  PUBLISHED
  SUSPENDED
  FAILED
}

enum AvatarEngine {
  DID
  TAVUS
  SIMLI
  SELF_HOSTED
  MOCK
}

enum WidgetTheme {
  LIGHT
}

enum WidgetPosition {
  BOTTOM_RIGHT
  BOTTOM_LEFT
}

enum AvatarAssetType {
  SOURCE_PHOTO
  CROPPED_PHOTO
  PREVIEW_PHOTO
  GENERATED_SPEECH_AUDIO
  GENERATED_AVATAR_VIDEO
  VOICE_INPUT_AUDIO
}

enum AvatarAssetValidationStatus {
  PENDING
  VALID
  INVALID
}

enum VoiceProvider {
  MOCK
  OPENAI
  ELEVENLABS
  AZURE
  CUSTOM
}

enum VoiceStatus {
  ACTIVE
  INACTIVE
}

enum ConversationChannel {
  DASHBOARD_PREVIEW
  WIDGET
  KIOSK
  API
}

enum ConversationStatus {
  ACTIVE
  ENDED
  HANDOFF_REQUESTED
  FAILED
}

enum MessageRole {
  VISITOR
  AVATAR
  SYSTEM
  OPERATOR
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
  SPAM
}

enum LeadSource {
  WIDGET
  DASHBOARD_PREVIEW
  KIOSK
  API
}

enum RuntimeTraceStatus {
  STARTED
  SUCCESS
  FAILURE
  SKIPPED
}

enum SafetyEventType {
  unsafe_user_input
  unsafe_avatar_instruction
  unsupported_medical_request
  unsupported_legal_request
  unsupported_financial_request
  impersonation_risk
  public_figure_risk
  fake_endorsement_risk
  abusive_message
  prompt_injection_attempt
  generated_answer_blocked
  generated_answer_rewritten
  handoff_forced
  lead_input_flagged
  consent_required
  avatar_suspended
}

enum SafetySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SafetyEventStatus {
  OPEN
  REVIEWED
  DISMISSED
  RESOLVED
}

enum SafetyAction {
  ALLOW
  WARN
  REWRITE
  REFUSE
  HANDOFF
  BLOCK
  SUSPEND_AVATAR
}

enum SafetySource {
  AVATAR_SETUP
  DASHBOARD_PREVIEW
  WIDGET_RUNTIME
  API_RUNTIME
  LEAD_CAPTURE
  SYSTEM
}

enum KnowledgeGapStatus {
  NEW
  IN_REVIEW
  RESOLVED
  IGNORED
}

enum KnowledgeGapReason {
  LOW_RETRIEVAL_CONFIDENCE
  NO_RELEVANT_KNOWLEDGE
  FALLBACK_USED
  USER_REPEATED_QUESTION
  SAFETY_HANDOFF
  OPERATOR_MARKED_POOR
  UNKNOWN
}

enum KnowledgeGapSource {
  DASHBOARD_PREVIEW
  WIDGET_RUNTIME
  API_RUNTIME
  SYSTEM
}

enum RealtimeSessionChannel {
  DASHBOARD_PREVIEW
  WIDGET
  API
}

enum RealtimeSessionStatus {
  STARTING
  ACTIVE
  ENDED
  FAILED
  EXPIRED
}

enum KnowledgeSourceType {
  FAQ
  TEXT
  WEBSITE
  PDF
}

enum KnowledgeStatus {
  PENDING
  READY
  FAILED
  ARCHIVED
}

enum ConsentType {
  SELF_IMAGE
  AUTHORIZED_STAFF
  BUSINESS_OWNED_CHARACTER
  LICENSED_SYNTHETIC_AVATAR
}

enum PermissionBasis {
  I_OWN_THIS_IMAGE
  I_HAVE_PERMISSION_FROM_PERSON_SHOWN
  BRAND_OWNED_FICTIONAL_OR_SYNTHETIC_CHARACTER
  PROPERLY_LICENSED_AVATAR_IMAGE
}
