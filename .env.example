NODE_ENV=development

# Core app
DATABASE_URL=postgresql://avatarkit:avatarkit@localhost:5432/avatarkit
WEB_PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_PUBLIC_API_BASE_URL=http://localhost:3000/api/public/v1
NEXT_PUBLIC_WIDGET_SCRIPT_URL=http://localhost:3000/widget.js
AVATARKIT_APP_BASE_URL=http://localhost:3000
SESSION_SECRET=<generate-secure-session-secret-if-enabled>

# TypeScript API service stub
API_HOST=0.0.0.0
API_PORT=4000

# Redis and queues
REDIS_URL=redis://localhost:6379
RATE_LIMIT_PROVIDER=memory
RATE_LIMIT_PUBLIC_API_MESSAGE_MAX=60
RATE_LIMIT_PUBLIC_API_MESSAGE_WINDOW_MS=60000
RATE_LIMIT_WIDGET_MESSAGE_MAX=30
RATE_LIMIT_WIDGET_MESSAGE_WINDOW_MS=60000
RATE_LIMIT_LEAD_SUBMIT_MAX=20
RATE_LIMIT_LEAD_SUBMIT_WINDOW_MS=60000
RATE_LIMIT_REALTIME_SESSION_MAX=20
RATE_LIMIT_REALTIME_SESSION_WINDOW_MS=60000
REDIS_REST_URL=
REDIS_REST_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Storage
STORAGE_PROVIDER=LOCAL
AVATARKIT_STORAGE_PROVIDER=LOCAL
LOCAL_STORAGE_ROOT=.data/uploads/avatar-assets
AVATAR_ASSET_STORAGE_ROOT=.data/uploads/avatar-assets
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
SUPABASE_STORAGE_BUCKET=
AVATAR_STORAGE_BUCKET=
AVATAR_STORAGE_REGION=
AVATAR_STORAGE_ENDPOINT=
AVATAR_STORAGE_ACCESS_KEY_ID=
AVATAR_STORAGE_SECRET_ACCESS_KEY=
AVATAR_STORAGE_PUBLIC_BASE_URL=

# Upload validation
AVATAR_PHOTO_MAX_FILE_SIZE_BYTES=8388608
AVATAR_PHOTO_MIN_WIDTH=512
AVATAR_PHOTO_MIN_HEIGHT=512
AVATAR_PHOTO_MAX_WIDTH=6000
AVATAR_PHOTO_MAX_HEIGHT=6000

# AI runtime
AI_RUNTIME_HOST=0.0.0.0
AI_RUNTIME_PORT=8000
AI_RUNTIME_BASE_URL=http://localhost:8000
AI_RUNTIME_SERVICE_TOKEN=<generate-secure-token>
AVATAR_RUNTIME_SERVICE_TOKEN=<same-as-ai-runtime-service-token-if-used>
AI_RUNTIME_PROVIDER=MOCK
AI_RUNTIME_REQUEST_TIMEOUT_MS=15000
AI_RUNTIME_OPENAI_MODEL=gpt-4o-mini
AI_RUNTIME_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# TTS and STT
AI_RUNTIME_TTS_PROVIDER=MOCK
AI_RUNTIME_STT_PROVIDER=MOCK
AI_RUNTIME_MOCK_STT_TRANSCRIPT=How can you help my business?
AI_RUNTIME_OPENAI_TTS_MODEL=gpt-4o-mini-tts
AI_RUNTIME_ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
AI_RUNTIME_OPENAI_STT_MODEL=whisper-1
AI_RUNTIME_DEEPGRAM_STT_MODEL=nova-2
ELEVENLABS_API_KEY=
DEEPGRAM_API_KEY=

# Avatar video providers
AI_RUNTIME_AVATAR_MEDIA_PROVIDER=MOCK
AI_RUNTIME_MOCK_AVATAR_VIDEO_URL=
DID_API_KEY=
DID_BASE_URL=https://api.d-id.com
DID_POLL_ATTEMPTS=6
TAVUS_API_KEY=
TAVUS_BASE_URL=https://tavusapi.com/v2
TAVUS_DEFAULT_REPLICA_ID=
TAVUS_DEFAULT_PERSONA_ID=
SIMLI_API_KEY=
SIMLI_BASE_URL=

# Phase 22 self-hosted research prototype only
AI_RUNTIME_SELF_HOSTED_AVATAR_MODE=DISABLED
AI_RUNTIME_SELF_HOSTED_AVATAR_ENDPOINT=
AI_RUNTIME_SELF_HOSTED_AVATAR_VIDEO_URL=
AI_RUNTIME_SELF_HOSTED_AVATAR_TIMEOUT_SECONDS=60
AI_RUNTIME_SELF_HOSTED_AVATAR_DURATION_SECONDS=3

# Widget and public runtime
AVATARKIT_ALLOWED_DEV_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_PUBLIC_API_CONFIG_MAX=120
RATE_LIMIT_PUBLIC_API_CONFIG_WINDOW_MS=60000
RATE_LIMIT_PUBLIC_API_CONVERSATION_MAX=40
RATE_LIMIT_PUBLIC_API_CONVERSATION_WINDOW_MS=60000
RATE_LIMIT_WIDGET_CONFIG_MAX=120
RATE_LIMIT_WIDGET_CONFIG_WINDOW_MS=60000
RATE_LIMIT_KIOSK_CONFIG_MAX=120
RATE_LIMIT_KIOSK_CONFIG_WINDOW_MS=60000
RATE_LIMIT_KIOSK_SESSION_MAX=30
RATE_LIMIT_KIOSK_SESSION_WINDOW_MS=60000
RATE_LIMIT_KIOSK_MESSAGE_MAX=60
RATE_LIMIT_KIOSK_MESSAGE_WINDOW_MS=60000
RATE_LIMIT_AUTH_ATTEMPT_MAX=20
RATE_LIMIT_AUTH_ATTEMPT_WINDOW_MS=60000
RATE_LIMIT_API_KEY_CREATE_MAX=10
RATE_LIMIT_API_KEY_CREATE_WINDOW_MS=60000

# Billing foundation placeholders
BILLING_PROVIDER=none
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_AGENCY=

# Webhooks
WEBHOOK_SIGNING_SECRET=<optional-global-signing-secret-if-delivery-worker-is-added>

# Admin and operations
PLATFORM_ADMIN_EMAILS=
OPERATIONS_READINESS_ENABLED=true
AUDIT_LOG_ENABLED=true
AUDIT_LOG_METADATA_MAX_LENGTH=4000
